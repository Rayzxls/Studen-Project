# ═══════════════════════════════════════════════════════════
# Beagle Classroom — Environment Variables
# Copy to .env.local and fill in actual values
# ═══════════════════════════════════════════════════════════

# ───── Node ─────
NODE_ENV=development

# ───── Database (Neon Postgres) ─────
# Get from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@host.neon.tech/beagle_classroom?sslmode=require"

# Required only by mutating integration/E2E tests. This must point to a
# completely separate PostgreSQL database or Neon branch, never production.
QA_DATABASE_URL="postgresql://user:password@qa-host.neon.tech/beagle_classroom_qa?sslmode=require"

# ───── Auth (NextAuth) ─────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ───── Rate Limit (Upstash Redis) ─────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ───── File Storage (Cloudflare R2) ─────
# Get from: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="beagle-classroom-dev"

# ───── CAPTCHA (Cloudflare Turnstile) ─────
# Get from: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ───── Monitoring (Sentry — optional) ─────
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ───── App Config ─────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Fail-closed rollout gate. Keep disabled until Production schema, transactional
# repository adapter, integration tests, and explicit release approval pass.
ACCOUNT_LIFECYCLE_MUTATIONS_ENABLED="0"

# Lesson Workspace rollout. Read and mutation flags fail closed. Omit the
# optional pilot allowlist to preserve all-course behaviour; once present, it
# must contain exact comma-separated CourseOffering ids. An empty allowlist
# enables no courses.
LESSON_WORKSPACE_ENABLED="0"
LESSON_WORKSPACE_MUTATIONS_ENABLED="0"
LESSON_WORKSPACE_DEFAULT_ROUTE_ENABLED="0"
# LESSON_WORKSPACE_PILOT_COURSE_IDS="course_id_for_pilot"

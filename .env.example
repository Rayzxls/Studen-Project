# ═══════════════════════════════════════════════════════════
# Beagle Classroom — Environment Variables
# Copy to .env.local and fill in actual values
# ═══════════════════════════════════════════════════════════

# ───── Node ─────
NODE_ENV=development

# ───── Database (Neon Postgres) ─────
# Get from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@host.neon.tech/beagle_classroom?sslmode=require"

# Required only by mutating integration/E2E tests. This must point to a
# completely separate PostgreSQL database or Neon branch, never production.
QA_DATABASE_URL="postgresql://user:password@qa-host.neon.tech/beagle_classroom_qa?sslmode=require"

# ───── Auth (NextAuth) ─────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ───── Rate Limit (Upstash Redis) ─────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ───── File Storage (Cloudflare R2) ─────
# Get from: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="beagle-classroom-dev"

# ───── CAPTCHA (Cloudflare Turnstile) ─────
# Get from: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ───── Monitoring (Sentry — optional) ─────
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ───── App Config ─────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Fail-closed rollout gate. Keep disabled until Production schema, transactional
# repository adapter, integration tests, and explicit release approval pass.
ACCOUNT_LIFECYCLE_MUTATIONS_ENABLED="0"

# Identity V2 additive foundation. Both flags fail closed. Do not enable reads
# or mutations until the additive migration is deployed to isolated QA and the
# Google/fallback onboarding services have passed their release gates.
IDENTITY_FOUNDATION_ENABLED="0"
IDENTITY_FOUNDATION_MUTATIONS_ENABLED="0"
IDENTITY_TERMS_VERSION=""
IDENTITY_PRIVACY_VERSION=""

# Google OAuth client. The id doubles as the required ID-token audience. Either
# value empty fails closed: the token verifier refuses to build and the Google
# provider is not registered, so the deployed sign-in options stay exactly as
# they are today. Both identity flags above must also be on.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Renders the Google sign-in button. Presentation only and defence-in-depth:
# the server provider gate above is the real control, so forcing this on can
# only show a button that fails, never a working sign-in. Keep "0" until the
# new-user onboarding flow exists, or new users hit a dead end.
NEXT_PUBLIC_GOOGLE_SIGNIN_ENABLED="0"

# Lesson Workspace rollout. Read and mutation flags fail closed. Omit the
# optional pilot allowlist to preserve all-course behaviour; once present, it
# must contain exact comma-separated CourseOffering ids. An empty allowlist
# enables no courses.
LESSON_WORKSPACE_ENABLED="0"
LESSON_WORKSPACE_MUTATIONS_ENABLED="0"
LESSON_WORKSPACE_DEFAULT_ROUTE_ENABLED="0"
# LESSON_WORKSPACE_PILOT_COURSE_IDS="course_id_for_pilot"

# Quiz rollout. All three values are required before any Quiz table is read or
# mutated. Keep disabled until the additive migration has been applied to an
# isolated QA branch and the exact pilot CourseOffering is approved. `*` is
# reserved for identity-checked isolated QA only, never Production.
QUIZ_ENABLED="0"
QUIZ_MUTATIONS_ENABLED="0"
# QUIZ_PILOT_COURSE_IDS="course_id_for_pilot"

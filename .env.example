# ═══════════════════════════════════════════════════════════
# Studennnn — Environment Variables
# Copy to .env.local and fill in actual values
# ═══════════════════════════════════════════════════════════

# ───── Node ─────
NODE_ENV=development

# ───── Database (Neon Postgres) ─────
# Get from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@host.neon.tech/studennnn?sslmode=require"

# ───── Auth (NextAuth) ─────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ───── Rate Limit (Upstash Redis) ─────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ───── File Storage (Cloudflare R2) ─────
# Get from: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="studennnn-dev"
R2_PUBLIC_URL=""

# ───── CAPTCHA (Cloudflare Turnstile) ─────
# Get from: https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ───── Monitoring (Sentry — optional) ─────
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ───── App Config ─────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/playwright/.cache

# next.js
/.next/
/.next-qa/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db
__pycache__/
*.pyc

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local agent dev-server logs + scratch dirs
next-dev-*.log
next-dev-*.err.log
vite-dev-*.log
vite-dev-*.err.log
*-qa.log
*-qa.err.log
.local-storage/
.codex/

# env files (commit only .env.example)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea

# Claude Code (per-user local settings)
.claude/settings.local.json

# Prisma (future phases)
/prisma/*.db
/prisma/*.db-journal

# Playwright MCP + taste skill scratch output
.playwright-mcp/
taste-*.jpeg
.tmp_preview/
~$*.docx

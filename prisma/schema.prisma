// Studennnn — Prisma Schema
// Phase 1: Identity + Auth + Audit
// Phase 2: Academic structure + Course Offerings + Enrollments
// Phase 4: Attendance (TimetableSlot + Session + AttendanceRecord) — ADR-0015, ADR-0016
// Phase 5: Scoring (ScoreItem + ScoreEntry) — ADR-0017, ADR-0018
// Phase 6: Assignment + Submission + Comment + FileAttachment — ADR-0019, ADR-0020, ADR-0021
// Workspace model (ADR-0012): teacher-owned CourseOffering, no school-wide Subject
// See: Architecture.md § 3 Data Model · Security.md · CONTEXT.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// Identity & Auth
// ═══════════════════════════════════════════════════════════

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
  ANONYMIZED
}

enum ThemeMode {
  SYSTEM
  LIGHT
  DARK
  CREAM
}

model User {
  id             String        @id @default(cuid())
  role           Role
  identifier     String        @unique // email (admin/teacher) | studentId (student)
  passwordHash   String
  mustResetPwd   Boolean       @default(false)
  accountStatus  AccountStatus @default(ACTIVE)
  isActive       Boolean       @default(true)
  consentedAt    DateTime?
  consentVersion String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime? // soft delete

  // Learning-identity profile (Phase 13) — NOT social media.
  // displayName: optional friendly name for personal UI (dashboard greeting,
  // profile heading) only. Real name stays authoritative everywhere else
  // (comments, review, grades, attendance, admin, audit). May duplicate.
  displayName    String?
  // Pointer to the current PROFILE_IMAGE FileAttachment (cropped 512×512).
  // Null = default avatar. Plain string (no FK) — FileAttachment is the
  // polymorphic table looked up via (ownerType, ownerId).
  profileImageId String?
  themeMode      ThemeMode @default(SYSTEM)

  admin                   Admin?
  teacher                 Teacher?
  student                 Student?
  sessions                UserSession[]
  auditLogsAsActor        AuditLog[]              @relation("ActorLogs")
  commentsAuthored        Comment[]               @relation("CommentAuthor")
  notifications           Notification[]          @relation("NotificationRecipient") // Phase 7
  materialsPosted         Material[]              @relation("MaterialAuthor") // Phase 7
  announcementsPosted     Announcement[]          @relation("AnnouncementAuthor") // Phase 7
  lifecycleEventsAsTarget AccountLifecycleEvent[] @relation("LifecycleTarget")
  lifecycleEventsAsActor  AccountLifecycleEvent[] @relation("LifecycleActor")
  moderationReports       ModerationReport[]      @relation("ModerationReporter")
  moderationCasesOwned    ModerationCase[]        @relation("ModerationOwner")
  moderationCasesReviewed ModerationCase[]        @relation("ModerationReviewer")
  moderationEventsAsActor ModerationCaseEvent[]   @relation("ModerationEventActor")

  @@index([role])
  @@index([accountStatus])
  @@index([deletedAt])
}

model AccountLifecycleEvent {
  id           String        @id @default(cuid())
  targetUserId String
  targetUser   User          @relation("LifecycleTarget", fields: [targetUserId], references: [id], onDelete: Restrict)
  actorUserId  String
  actorUser    User          @relation("LifecycleActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  fromStatus   AccountStatus
  toStatus     AccountStatus
  reason       String
  userMessage  String
  createdAt    DateTime      @default(now())

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
}

enum ModerationTargetType {
  COMMENT
  ANNOUNCEMENT
  MATERIAL
  ASSIGNMENT
  QUIZ
  QUIZ_QUESTION
  FILE_ATTACHMENT
  PROFILE_IMAGE
}

enum ModerationCaseStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
  APPEALED
}

enum ModerationReportCategory {
  HARASSMENT
  INAPPROPRIATE_CONTENT
  PRIVACY
  COPYRIGHT
  SPAM
  OTHER
}

enum ModerationRestrictionKind {
  HIDDEN
  QUARANTINED
}

enum ModerationCaseEventType {
  REPORT_ADDED
  REVIEW_STARTED
  TEMPORARILY_RESTRICTED
  RESTRICTION_RESTORED
  RESOLVED
  DISMISSED
  APPEAL_SUBMITTED
}

model ModerationCase {
  id               String                     @id @default(cuid())
  activeKey        String?                    @unique
  targetType       ModerationTargetType
  targetId         String
  targetLabel      String
  targetSnapshot   Json
  courseOfferingId String?
  ownerUserId      String?
  ownerUser        User?                      @relation("ModerationOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  status           ModerationCaseStatus       @default(OPEN)
  reportCount      Int                        @default(0)
  priority         Int                        @default(0)
  restrictionKind  ModerationRestrictionKind?
  restrictedAt     DateTime?
  restrictedById   String?
  restrictedReason String?
  decisionSummary  String?
  userMessage      String?
  resolvedAt       DateTime?
  resolvedById     String?
  resolvedBy       User?                      @relation("ModerationReviewer", fields: [resolvedById], references: [id], onDelete: SetNull)
  appealDeadline   DateTime?
  appealUsed       Boolean                    @default(false)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  reports ModerationReport[]
  events  ModerationCaseEvent[]

  @@index([status, priority, createdAt])
  @@index([targetType, targetId])
  @@index([courseOfferingId, status])
  @@index([ownerUserId, status])
}

model ModerationReport {
  id         String                   @id @default(cuid())
  caseId     String
  case       ModerationCase           @relation(fields: [caseId], references: [id], onDelete: Restrict)
  reporterId String
  reporter   User                     @relation("ModerationReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  category   ModerationReportCategory
  details    String
  createdAt  DateTime                 @default(now())

  @@unique([caseId, reporterId])
  @@index([reporterId, createdAt])
}

model ModerationCaseEvent {
  id          String                  @id @default(cuid())
  caseId      String
  case        ModerationCase          @relation(fields: [caseId], references: [id], onDelete: Restrict)
  actorUserId String
  actorUser   User                    @relation("ModerationEventActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  type        ModerationCaseEventType
  reason      String?
  userMessage String?
  metadata    Json?
  createdAt   DateTime                @default(now())

  @@index([caseId, createdAt])
  @@index([actorUserId, createdAt])
}

model Admin {
  userId    String @id
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
}

model Teacher {
  userId       String  @id
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  email        String  @unique
  homeroomOfId String? @unique // FK to Class (1:1)
  homeroomOf   Class?  @relation("HomeroomOf", fields: [homeroomOfId], references: [id])

  courses CourseOffering[]
}

model Student {
  userId     String  @id
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId  String  @unique
  firstName  String
  lastName   String
  anonymized Boolean @default(false)
  classId    String?
  class      Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  enrollments Enrollment[]
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════════════════════
// Audit
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  actorId     String?
  actor       User?    @relation("ActorLogs", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole   Role?
  action      String // SCORE_EDIT_AFTER_PUBLISH | LOGIN_SUCCESS | LOGIN_FAILED | ...
  targetType  String?
  targetId    String?
  targetLabel String? // human-readable snapshot of the target — captured at fire time (ADR-0027 / Phase 10 Q9d). Null for legacy rows; null on render → "—".
  before      Json?
  after       Json?
  reason      String?
  ipAddress   String?
  userAgent   String?

  @@index([actorId, timestamp])
  @@index([action, timestamp])
  @@index([targetType, targetId])
}

// ═══════════════════════════════════════════════════════════
// Academic Structure (Phase 2)
// ═══════════════════════════════════════════════════════════

model AcademicYear {
  id       String  @id @default(cuid())
  name     String  @unique // "2568" (พ.ศ.)
  isActive Boolean @default(false) // current academic year
  terms    Term[]
  classes  Class[]
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String // "เทอม 1/2568"
  number         Int // 1 or 2
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(false)

  courses CourseOffering[]

  @@unique([academicYearId, number])
}

model Class {
  id              String       @id @default(cuid())
  academicYearId  String
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name            String // "ม.4/2"
  gradeLevel      String // "ม.4"
  homeroomTeacher Teacher?     @relation("HomeroomOf")

  students Student[]
  courses  CourseOffering[]

  @@unique([academicYearId, name])
  @@index([gradeLevel])
}

model CourseOffering {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [userId], onDelete: Restrict)
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Restrict)
  termId    String
  term      Term    @relation(fields: [termId], references: [id], onDelete: Restrict)

  // Workspace fields (teacher-defined) — replaces former Subject FK
  name        String // "คณิตศาสตร์ ม.4 ครูสมชาย"
  subjectCode String? // optional teacher-set code for transcript ("MATH-M4")
  gradeLevel  String // "ม.4" (defaults to class.gradeLevel on create)
  creditHours Float // หน่วยกิต e.g. 1.5

  classCode      String    @unique
  codeActive     Boolean   @default(true)
  codeExpiresAt  DateTime?
  gradeRulesJson Json? // override default grade thresholds
  createdAt      DateTime  @default(now())
  archivedAt     DateTime?
  archivedById   String?
  archivedReason String?

  enrollments    Enrollment[]
  timetableSlots TimetableSlot[]
  sessions       Session[]
  scoreItems     ScoreItem[]
  lessons        Lesson[]
  quizzes        Quiz[]
  assignments    Assignment[]
  materials      Material[] // Phase 7
  announcements  Announcement[] // Phase 7

  @@index([classCode])
  @@index([teacherId])
  @@index([classId, termId])
  @@index([archivedAt])
}

model Enrollment {
  id               String         @id @default(cuid())
  studentId        String
  student          Student        @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  enrolledAt       DateTime       @default(now())

  // Phase 3 — soft-delete + audit trail (ADR-0013)
  removedAt     DateTime?
  removedById   String? // User.id of the actor who removed/left the course
  removedReason String? // Min 5 chars enforced at API boundary

  attendanceRecords AttendanceRecord[]
  scoreEntries      ScoreEntry[]
  submissions       Submission[]
  quizAttempts      QuizAttempt[]
  quizExceptions    QuizStudentException[]

  @@unique([studentId, courseOfferingId])
  @@index([courseOfferingId])
  @@index([removedAt]) // fast "active members" filtering (where removedAt: null)
}

// ═══════════════════════════════════════════════════════════
// Attendance (Phase 4) — ADR-0015 (lazy materialization) · ADR-0016 (sparse records + Enrollment FK)
// ═══════════════════════════════════════════════════════════

// Template — recurring weekly schedule. Optional per CourseOffering.
// Editing/deleting a slot does NOT propagate to existing Session rows (ADR-0015 § 4).
model TimetableSlot {
  id               String         @id @default(cuid())
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  dayOfWeek        Int // 0=Sun..6=Sat (matches JS Date.getDay())
  startTime        String // "HH:mm" 24h, local Bangkok time
  endTime          String // "HH:mm" 24h, local Bangkok time
  location         String? // "อาคาร 3 ห้อง 305"
  createdAt        DateTime       @default(now())

  sessions Session[]

  // Intra-course overlap blocking: exact duplicate slot rejected at DB layer.
  // Time-range overlap (different startTime) blocked at lib layer (Q4a).
  @@unique([courseOfferingId, dayOfWeek, startTime])
  @@index([courseOfferingId])
}

// Concrete class meeting — materialized lazily on first teacher action.
// Created via findOrCreateSession({courseOfferingId, scheduledStart, ...}).
model Session {
  id               String         @id @default(cuid())
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)

  // Provenance — null = manually opened ad-hoc.
  // SetNull so deleting a TimetableSlot does not orphan historical Sessions.
  timetableSlotId String?
  timetableSlot   TimetableSlot? @relation(fields: [timetableSlotId], references: [id], onDelete: SetNull)

  scheduledStart DateTime // UTC instant (Postgres TIMESTAMPTZ); display layer converts to Asia/Bangkok
  scheduledEnd   DateTime
  note           String?

  // Soft-cancel — see ADR-0015 § 3, audit event SESSION_CANCELLED (Critical tier).
  cancelledAt     DateTime?
  cancelledById   String?
  cancelledReason String? // Min 5 chars enforced at action layer

  createdAt   DateTime @default(now())
  createdById String // Teacher who opened the session (Restrict via Teacher FK enforced at lib layer)

  records AttendanceRecord[]

  // Prevents race-condition double-create from concurrent "เปิดคาบ" clicks.
  @@unique([courseOfferingId, scheduledStart])
  // Grid list query: "Sessions of this course, newest first"
  @@index([courseOfferingId, scheduledStart])
  @@index([timetableSlotId])
}

enum AttendanceStatus {
  PRESENT
  LATE
  EXCUSED
  ABSENT
}

// Sparse — no row = "ยังไม่เช็ค" (not yet marked), distinct from ABSENT (ADR-0016 § 1).
model AttendanceRecord {
  id           String           @id @default(cuid())
  sessionId    String
  session      Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollmentId String
  enrollment   Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  status       AttendanceStatus
  note         String? // "ลาป่วยมีใบรับรอง", "สาย 15 นาที"

  markedAt   DateTime @default(now()) // first mark — stable
  markedById String // teacher who last marked (overwritten on edit)
  updatedAt  DateTime @updatedAt
  editCount  Int      @default(0) // increments on each edit; back-edit reason required when scheduledStart > 24h ago

  @@unique([sessionId, enrollmentId])
  @@index([enrollmentId]) // student stats query
  @@index([sessionId])
}

// ═══════════════════════════════════════════════════════════
// Scoring (Phase 5 + Phase 10) — ADR-0024 (sum-based, supersedes ADR-0017) · ADR-0018 (publish one-way + class A/C edit rules — class B narrowed to {fullScore})
// ═══════════════════════════════════════════════════════════

enum ScoreItemSource {
  MANUAL // teacher created manually via Score Item form
  ASSIGNMENT_LINKED // created automatically when Assignment.isScored=true (Phase 6)
  QUIZ_LINKED // created atomically for a scored Quiz (Release C, ADR-0036)
}

// One scoring "slot" per CourseOffering — name + fullScore.
// Influence in the course grade is proportional to fullScore (Σscore/ΣfullScore × 100) — ADR-0024.
// publishedAt is set exactly once; never null again — ADR-0018 (no unpublish).
model ScoreItem {
  id               String          @id @default(cuid())
  courseOfferingId String
  course           CourseOffering  @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  name             String // teacher-defined, ≤ 200 chars (validated at API boundary)
  fullScore        Int // > 0 (validated at API boundary); also expresses proportional influence in course grade per ADR-0024
  source           ScoreItemSource @default(MANUAL)
  position         Int             @default(0) // display order within the CourseOffering
  publishedAt      DateTime? // null = draft; non-null = visible to students (one-way per ADR-0018)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  entries    ScoreEntry[]
  assignment Assignment? // 1:1 reverse — set when source=ASSIGNMENT_LINKED (ADR-0019)
  quiz       Quiz? // 1:1 reverse — set when source=QUIZ_LINKED (ADR-0036)

  @@index([courseOfferingId, position]) // ordered list rendering
  @@index([courseOfferingId, publishedAt]) // term-GPA completion check
}

// One row per (Enrollment × ScoreItem). Value stored as Int (whole points).
// FK to Enrollment (not Student) per Pattern 14 / ADR-0016 — preserves trace
// across soft-deleted Enrollment rows.
model ScoreEntry {
  id           String     @id @default(cuid())
  scoreItemId  String
  scoreItem    ScoreItem  @relation(fields: [scoreItemId], references: [id], onDelete: Restrict)
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  value        Int // 0..fullScore (validated at API boundary against parent ScoreItem.fullScore)
  note         String? // optional teacher comment for this specific entry

  markedAt   DateTime @default(now()) // first mark — stable, not overwritten on edit
  markedById String // teacher who last marked (overwritten on edit)
  updatedAt  DateTime @updatedAt
  editCount  Int      @default(0) // increments per edit; post-publish edits require reason ≥ 5 → audit SCORE_EDIT_AFTER_PUBLISH

  @@unique([scoreItemId, enrollmentId])
  @@index([enrollmentId]) // student-facing "my scores" query
  @@index([scoreItemId]) // teacher-facing scoreboard query
}

// ═══════════════════════════════════════════════════════════
// Assignment + Submission (Phase 6) — ADR-0019 (Assignment ↔ ScoreItem coupling) · ADR-0020 (Submission lifecycle)
// ═══════════════════════════════════════════════════════════

enum SubmissionStatus {
  NOT_SUBMITTED // sentinel — no Submission row materialised yet (queries surface this as a derived state)
  DRAFT // student started editing v1 but hasn't submitted yet
  SUBMITTED // current SubmissionVersion is on-time
  LATE_SUBMITTED // current SubmissionVersion is past dueAt
  RETURNED // teacher returned; student may resubmit
  GRADED // teacher finished grading (scored Assignment: ScoreItem published; ungraded: marked done)
}

// Teacher-defined content structure inside one CourseOffering.
// Lesson is additive: existing Assignment and Material rows may remain
// course-wide until the guarded B2 compatibility backfill is approved.
model Lesson {
  id               String         @id @default(cuid())
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)

  title       String
  description String?
  position    Int     @default(0)

  archivedAt     DateTime?
  archivedById   String?
  archivedReason String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments Assignment[]
  materials   Material[]
  quizzes     Quiz[]

  @@index([courseOfferingId, position])
  @@index([courseOfferingId, archivedAt])
}

// ═══════════════════════════════════════════════════════════
// Quiz (Release C foundation) — ADR-0035..0038
// Additive only. No route or mutation is enabled without fail-closed flags.
// ═══════════════════════════════════════════════════════════

enum QuizMode {
  PRACTICE
  SCORED
}

enum QuizStatus {
  DRAFT
  OPEN
  CLOSED
}

enum QuizQuestionType {
  SINGLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
}

enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
}

enum QuizSubmissionTrigger {
  MANUAL
  DEADLINE
  QUIZ_CLOSED
}

model Quiz {
  id               String         @id @default(cuid())
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  lessonId         String
  lesson           Lesson         @relation(fields: [lessonId], references: [id], onDelete: Restrict)

  title       String
  description String?
  mode        QuizMode
  status      QuizStatus @default(DRAFT)
  required    Boolean    @default(false)
  position    Int        @default(0)
  revision    Int        @default(1)

  opensAt              DateTime?
  closesAt             DateTime?
  timeLimitMinutes     Int?
  maxAttempts          Int?
  passThresholdPercent Int?
  shuffleQuestions     Boolean   @default(false)
  shuffleOptions       Boolean   @default(false)
  hideExplanations     Boolean   @default(false)
  fileAttachmentIds    Json      @default("[]")

  // Practice has no ScoreItem. Scored owns exactly one QUIZ_LINKED ScoreItem;
  // the atomic invariant is enforced by the service boundary (ADR-0036).
  scoreItemId String?    @unique
  scoreItem   ScoreItem? @relation(fields: [scoreItemId], references: [id], onDelete: SetNull)

  cancelledAt     DateTime?
  cancelledById   String?
  cancelledReason String?
  archivedAt      DateTime?
  archivedById    String?
  archivedReason  String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions         QuizQuestion[]
  attempts          QuizAttempt[]
  studentExceptions QuizStudentException[]

  @@index([courseOfferingId, status, position])
  @@index([lessonId, status, position])
  @@index([scoreItemId])
  @@index([archivedAt])
}

model QuizQuestion {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  type              QuizQuestionType
  prompt            String
  explanation       String?
  points            Int
  position          Int
  fileAttachmentIds Json             @default("[]")

  voidedAt     DateTime?
  voidedById   String?
  voidedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options QuizOption[]
  answers QuizAnswer[]

  @@unique([quizId, position])
  @@index([quizId, voidedAt])
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  text              String
  isCorrect         Boolean @default(false)
  position          Int
  fileAttachmentIds Json    @default("[]")

  @@unique([questionId, position])
  @@index([questionId])
}

model QuizAttempt {
  id           String     @id @default(cuid())
  quizId       String
  quiz         Quiz       @relation(fields: [quizId], references: [id], onDelete: Restrict)
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)

  attemptNumber     Int
  status            QuizAttemptStatus      @default(IN_PROGRESS)
  startedAt         DateTime               @default(now())
  effectiveDeadline DateTime?
  submittedAt       DateTime?
  submissionTrigger QuizSubmissionTrigger?

  // Complete immutable content/grading snapshot. Attachment entries contain
  // ids and display metadata only, never an R2 key or reusable signed URL.
  snapshotRevision Int
  snapshotJson     Json

  autoScore      Int?
  finalScore     Int?
  adjustedAt     DateTime?
  adjustedById   String?
  adjustedReason String?

  // One active writer. Only the hash is stored; takeover increments version.
  leaseVersion   Int       @default(1)
  leaseTokenHash String?
  leaseExpiresAt DateTime?
  writeRevision  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers   QuizAnswer[]
  mutations QuizAttemptMutation[]

  @@unique([quizId, enrollmentId, attemptNumber])
  @@index([quizId, status])
  @@index([enrollmentId, status])
  @@index([effectiveDeadline, status])
}

model QuizAnswer {
  id         String       @id @default(cuid())
  attemptId  String
  attempt    QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)

  answerJson    Json
  isCorrect     Boolean?
  awardedPoints Int?
  answeredAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([attemptId, questionId])
  @@index([questionId])
}

model QuizAttemptMutation {
  id             String      @id @default(cuid())
  attemptId      String
  attempt        QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  idempotencyKey String
  resultRevision Int
  responseJson   Json
  createdAt      DateTime    @default(now())

  @@unique([attemptId, idempotencyKey])
  @@index([attemptId, createdAt])
}

model QuizStudentException {
  id           String     @id @default(cuid())
  quizId       String
  quiz         Quiz       @relation(fields: [quizId], references: [id], onDelete: Restrict)
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)

  extendedDeadline DateTime?
  extraAttempts    Int       @default(0)
  reason           String
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([quizId, enrollmentId])
  @@index([enrollmentId])
}

// Per CourseOffering — title, description, deadline, file/text/link toggles.
// Optional 1:1 link to a ScoreItem when isScored=true (ADR-0019 § 1 — created
// atomically in the same $transaction as Assignment.create or as the
// isScored:false→true flip). schema never carries
// "isScored=true AND scoreItemId IS NULL" — invariant enforced at lib layer.
model Assignment {
  id               String         @id @default(cuid())
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)

  // Optional during B1/B2 compatibility. Service-layer checks must ensure
  // the Lesson belongs to this same CourseOffering before linking content.
  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  title       String // teacher-defined, ≤ 200 chars (validated at API boundary)
  description String // markdown subset, ≤ 10000 chars

  // Teacher-attached reference links on the assignment brief — students open
  // these to do the work (e.g. a website to research). Distinct from
  // SubmissionVersion.links (the student's submitted answers) and from
  // allowLink (whether students MAY submit links). JSON string[] of URLs.
  linkUrls Json @default("[]")

  // Teacher-attached worksheet/example files on the assignment brief.
  // FileAttachment rows use ownerType=ASSIGNMENT + ownerId=this Assignment.id.
  fileAttachmentIds Json @default("[]")

  dueAt     DateTime? // UTC instant; null = "ส่งเมื่อพร้อม"
  allowText Boolean   @default(true)
  allowFile Boolean   @default(true)
  allowLink Boolean   @default(false)

  // Submission window controls — independent hard stops (ADR-0020 § 3).
  // submissionClosed = manual hard stop; autoCloseAtDue = lazy soft stop
  // (refuse new SubmissionVersion at write time when now >= dueAt, no cron).
  submissionClosed Boolean @default(false)
  autoCloseAtDue   Boolean @default(false)

  // ScoreItem coupling (ADR-0019). scoreItemId is unique → 1:1 with ScoreItem.
  // SetNull on delete: when ScoreItem is removed via the Critical-tier
  // deleteScoreItem path (ADR-0018), Assignment.scoreItemId becomes null.
  // The invariant "isScored=true ⇒ scoreItemId IS NOT NULL" holds in
  // steady state at the lib/assignment.* boundary — deleteScoreItem may
  // briefly land Assignment in (isScored=true, scoreItemId=null) which the
  // next toggle isScored:true→false call cleans up.
  isScored    Boolean    @default(false)
  scoreItemId String?    @unique
  scoreItem   ScoreItem? @relation(fields: [scoreItemId], references: [id], onDelete: SetNull)

  createdById String // User.id of the teacher who created it
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]

  @@index([courseOfferingId, createdAt])
  @@index([lessonId, createdAt])
  @@index([scoreItemId])
}

// One row per (Enrollment × Assignment). Holds the chain of SubmissionVersions.
// status is denormalised from the current version's isLate + workflow signal
// (DRAFT → SUBMITTED/LATE_SUBMITTED → RETURNED → GRADED) per ADR-0020 § 2.
// FK to Enrollment uses Restrict per ADR-0013 — preserve trace across soft-delete.
model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)

  status SubmissionStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions SubmissionVersion[]

  @@unique([assignmentId, enrollmentId])
  @@index([assignmentId, status]) // teacher grid filter by status
  @@index([enrollmentId]) // student "my submissions" query
}

// One row per submit/resubmit action. Past versions persist with isCurrent=false
// (audit trail per CONTEXT § SubmissionVersion). Exactly one version per
// Submission has isCurrent=true — invariant enforced at lib layer inside the
// submit transaction (set previous current to false in the same tx).
// isLate is immutable, computed at submittedAt against Assignment.dueAt
// (ADR-0020 § 2 — per-version, status moves forward only).
model SubmissionVersion {
  id            String     @id @default(cuid())
  submissionId  String
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  versionNumber Int // 1, 2, 3, ...

  textContent       String? // markdown subset, ≤ 50000 chars
  links             Json // string[] URLs, validated at API boundary (≤ 10 per version, each ≤ 2000 chars)
  fileAttachmentIds Json    @default("[]") // string[] of FileAttachment.id under owner SUBMISSION (P7-0a) — ordered pointer array per version; files attach to parent Submission (chicken-and-egg per ADR-0021), pointer array per version snapshots which ones belong to this submit

  submittedAt DateTime @default(now())
  isLate      Boolean // immutable — computed at submit-time vs Assignment.dueAt
  isCurrent   Boolean  @default(true)

  // Student soft-hide (ADR-0020): when set, this version is filtered out of
  // the student's OWN history list, but the teacher + audit trail still see
  // it — history is never destroyed. Only non-current versions may be hidden.
  hiddenFromStudentAt DateTime?

  @@unique([submissionId, versionNumber])
  @@index([submissionId, isCurrent]) // "find current version" query
}

// ═══════════════════════════════════════════════════════════
// File Attachments (Phase 6) — ADR-0021 (R2 pipeline)
// ═══════════════════════════════════════════════════════════

enum FileOwnerType {
  ASSIGNMENT // attached by teacher to the assignment brief
  MATERIAL // teacher post (Phase 7 — reserved)
  ANNOUNCEMENT // teacher post (Phase 7 — reserved)
  QUIZ // Quiz-level reference file (Release C)
  QUIZ_QUESTION // question/explanation file (Release C)
  QUIZ_OPTION // option-level file (Release C)
  SUBMISSION // student-submitted file — attached to parent Submission (P7-0a); SubmissionVersion.fileAttachmentIds is the per-version pointer array
  COMMENT // file embedded in a comment (Phase 7 — reserved)
  PROFILE_IMAGE // user's own cropped avatar — ownerId = User.id (Phase 13)
}

// Polymorphic file attachment table — ownerType + ownerId rather than a per-owner FK.
// Permission check happens at sign time against the owner row; FileAttachment
// itself has no FK back to owners (looked up via (ownerType, ownerId) index).
// r2Key is assembled by lib/storage as
// permanent/<ownerType>/<ownerId>/<uuid>.<verifiedExt> (ADR-0021 § 4) — never
// derived from user filename; user filename is display-only in originalFilename.
model FileAttachment {
  id String @id @default(cuid())

  r2Key            String @unique
  originalFilename String // display only, sanitised on render
  mimeType         String // verified via file-type magic-byte at commit (ADR-0021 § 2)
  sizeBytes        Int // ≤ 20_971_520 (20 MB) enforced at presign + commit

  ownerType FileOwnerType
  ownerId   String

  uploadedById String // User.id of the uploader
  uploadedAt   DateTime @default(now())

  // Soft delete — moderation or owner removal (FILE_DELETED Important audit)
  deletedAt     DateTime?
  deletedById   String?
  deletedReason String? // ≥ 5 chars when moderated

  @@index([ownerType, ownerId]) // primary lookup for rendering attachments
  @@index([uploadedById])
}

// ═══════════════════════════════════════════════════════════
// Comments (Phase 6) — ADR-0020 (private comments on Submission) · CONTEXT § Comment Moderation
// ═══════════════════════════════════════════════════════════

enum CommentScope {
  CLASS_WIDE // visible to all CourseOffering members — attached to ASSIGNMENT/MATERIAL/ANNOUNCEMENT
  PRIVATE // visible to author + teacher (and admin for moderation) — attached to SUBMISSION
}

enum CommentOwnerType {
  ASSIGNMENT
  MATERIAL // Phase 7 — reserved
  ANNOUNCEMENT // Phase 7 — reserved
  SUBMISSION // PRIVATE-scoped comments live here, including the RETURN reason (ADR-0020 § 1)
}

// Comments are polymorphic on (ownerType, ownerId). Soft-delete supports the
// Q5 moderation matrix — author self-delete (Verbose), Teacher moderate
// (Important + reason ≥ 5), Admin moderate PRIVATE (Critical-tier).
// authorId uses Restrict — preserve historical authorship even after a User
// is soft-deleted via User.deletedAt + anonymisation.
model Comment {
  id String @id @default(cuid())

  ownerType CommentOwnerType
  ownerId   String

  scope CommentScope

  authorId String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  body String // ≥ 5 chars when used as RETURN reason (ADR-0020 § 1)

  createdAt DateTime  @default(now())
  editedAt  DateTime? // set when author edits within the 5-min self-window

  // Soft delete — Q5 moderation matrix
  deletedAt     DateTime?
  deletedById   String? // moderator (teacher/admin) or author for self-delete
  deletedReason String? // ≥ 5 chars when moderated; null on self-delete

  @@index([ownerType, ownerId, createdAt]) // thread render
  @@index([authorId])
}

// ═══════════════════════════════════════════════════════════
// Rate Limit (in-DB, fallback when Redis not available)
// Phase 1 simple version — Phase 9 migrate to Upstash Redis
// ═══════════════════════════════════════════════════════════

model RateLimitBucket {
  id        String    @id // "<action>:<identifier>" e.g. "login:admin@example.com"
  count     Int       @default(0)
  resetAt   DateTime
  lockedAt  DateTime?
  updatedAt DateTime  @updatedAt

  @@index([resetAt])
}

// ═══════════════════════════════════════════════════════════
// Notifications (Phase 7) — ADR-0022
// Fan-out rows · in-tx delivery · snapshot payload · soft suppress.
// Partial unique index on post-once kinds is applied via raw SQL
// after `prisma db push` (Prisma 6 @@unique does not support WHERE).
// See prisma/raw-sql/0001-notification-partial-unique.sql.
// ═══════════════════════════════════════════════════════════

enum NotificationKind {
  // Broadcast — 1 row per active enrollment
  SCORE_ITEM_PUBLISHED
  ASSIGNMENT_POSTED
  MATERIAL_POSTED
  ANNOUNCEMENT_POSTED
  // Targeted — 1 row per affected student
  SCORE_ENTRY_EDITED // post-publish, value-change-only, 1 per student per batch
  SUBMISSION_GRADED
  SUBMISSION_RETURNED // merges with the private RETURN comment
  // Thread — fan-out to thread participants ∪ entity author − self
  COMMENT_REPLIED
  // Teacher
  CLASS_CODE_JOINED
}

enum NotifEntityType {
  SCORE_ITEM
  ASSIGNMENT
  MATERIAL
  ANNOUNCEMENT
  SUBMISSION
  COMMENT
  ENROLLMENT // for CLASS_CODE_JOINED
}

model Notification {
  id String @id @default(cuid())

  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  kind             NotificationKind
  sourceEntityType NotifEntityType
  sourceEntityId   String

  // Snapshot of entity at fan-out time — bell renders without joining
  // source tables (ADR-0022 § 4). Accepts drift on entity edits in
  // exchange for immutability + dead-entity graceful fallback.
  payloadJson Json

  // Denormalized for suppress-batch lookup (ADR-0022 § 5) + future
  // per-course filter. Nullable to leave room for system-wide
  // notifications in Phase 8+ (Q7.2 grill lock).
  courseOfferingId String?

  readAt       DateTime?
  suppressedAt DateTime?
  createdAt    DateTime  @default(now())

  // Bell list + badge count: WHERE recipientId = me AND
  //   suppressedAt IS NULL ORDER BY createdAt DESC.
  // The composite index (recipientId, readAt, createdAt DESC) covers
  // both the unread-count and the chronological list query plans.
  @@index([recipientId, readAt, createdAt(sort: Desc)])
  // Suppress-batch on removeMember + entity soft-delete cascade.
  @@index([recipientId, courseOfferingId, suppressedAt])
}

// ═══════════════════════════════════════════════════════════
// Material + Announcement (Phase 7)
// Teacher-posted content — no submission, no scored coupling.
// Material = study resource ("ต้องอ่าน/ใช้"); Announcement = news/info.
// Comments are CLASS_WIDE only (CONTEXT § Comment Scope + Q12.7 lock).
// ═══════════════════════════════════════════════════════════

model Material {
  id String @id @default(cuid())

  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)

  // Optional during B1/B2 compatibility; General Announcements intentionally
  // stay course-wide and therefore do not carry a Lesson relation.
  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  // 1..200 chars (validated at lib/material/validation)
  title String

  // 0..5000 chars, markdown subset (rendered via react-markdown + rehype-sanitize)
  body String

  // Ordered pointer arrays — mirror SubmissionVersion.fileAttachmentIds
  // pattern. FileAttachment rows live under owner SUBMISSION/ASSIGNMENT
  // and ownerType=MATERIAL once wired through P7-3 + P7-7.
  fileAttachmentIds Json @default("[]")
  linkUrls          Json @default("[]") // ≤ 5 URLs per Q12.4 lock

  postedById String
  postedBy   User     @relation("MaterialAuthor", fields: [postedById], references: [id], onDelete: Restrict)
  postedAt   DateTime @default(now())

  // Soft-delete — `MATERIAL_DELETED` Important audit fires here per
  // Q4.2 (edit free + Verbose, delete = Important).
  deletedAt     DateTime?
  deletedById   String?
  deletedReason String? // ≥ 5 chars when present

  @@index([courseOfferingId, postedAt(sort: Desc)])
  @@index([lessonId, postedAt(sort: Desc)])
  @@index([deletedAt])
}

model Announcement {
  id String @id @default(cuid())

  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)

  // 0..200 chars optional (Q4.1 = b — body required, title optional)
  title String?

  // 0..5000 chars, markdown subset
  body String

  fileAttachmentIds Json @default("[]")
  linkUrls          Json @default("[]")

  postedById String
  postedBy   User     @relation("AnnouncementAuthor", fields: [postedById], references: [id], onDelete: Restrict)
  postedAt   DateTime @default(now())

  deletedAt     DateTime?
  deletedById   String?
  deletedReason String?

  @@index([courseOfferingId, postedAt(sort: Desc)])
  @@index([deletedAt])
}

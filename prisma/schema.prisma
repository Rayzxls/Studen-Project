// Studennnn — Prisma Schema
// Phase 1: Identity + Auth + Audit
// Phase 2: Academic structure + Course Offerings + Enrollments
// Phase 4: Attendance (TimetableSlot + Session + AttendanceRecord) — ADR-0015, ADR-0016
// Workspace model (ADR-0012): teacher-owned CourseOffering, no school-wide Subject
// See: Architecture.md § 3 Data Model · Security.md · CONTEXT.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// Identity & Auth
// ═══════════════════════════════════════════════════════════

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id             String    @id @default(cuid())
  role           Role
  identifier     String    @unique // email (admin/teacher) | studentId (student)
  passwordHash   String
  mustResetPwd   Boolean   @default(false)
  isActive       Boolean   @default(true)
  consentedAt    DateTime?
  consentVersion String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // soft delete

  admin            Admin?
  teacher          Teacher?
  student          Student?
  sessions         UserSession[]
  auditLogsAsActor AuditLog[]    @relation("ActorLogs")

  @@index([role])
  @@index([deletedAt])
}

model Admin {
  userId    String @id
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
}

model Teacher {
  userId       String  @id
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  email        String  @unique
  homeroomOfId String? @unique // FK to Class (1:1)
  homeroomOf   Class?  @relation("HomeroomOf", fields: [homeroomOfId], references: [id])

  courses CourseOffering[]
}

model Student {
  userId     String  @id
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId  String  @unique
  firstName  String
  lastName   String
  anonymized Boolean @default(false)
  classId    String?
  class      Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  enrollments Enrollment[]
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════════════════════
// Audit
// ═══════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  actorId    String?
  actor      User?    @relation("ActorLogs", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole  Role?
  action     String // SCORE_EDIT_AFTER_PUBLISH | LOGIN_SUCCESS | LOGIN_FAILED | ...
  targetType String?
  targetId   String?
  before     Json?
  after      Json?
  reason     String?
  ipAddress  String?
  userAgent  String?

  @@index([actorId, timestamp])
  @@index([action, timestamp])
  @@index([targetType, targetId])
}

// ═══════════════════════════════════════════════════════════
// Academic Structure (Phase 2)
// ═══════════════════════════════════════════════════════════

model AcademicYear {
  id       String  @id @default(cuid())
  name     String  @unique // "2568" (พ.ศ.)
  isActive Boolean @default(false) // current academic year
  terms    Term[]
  classes  Class[]
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String // "เทอม 1/2568"
  number         Int // 1 or 2
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(false)

  courses CourseOffering[]

  @@unique([academicYearId, number])
}

model Class {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  name           String // "ม.4/2"
  gradeLevel     String // "ม.4"
  homeroomTeacher Teacher? @relation("HomeroomOf")

  students Student[]
  courses  CourseOffering[]

  @@unique([academicYearId, name])
  @@index([gradeLevel])
}

model CourseOffering {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [userId], onDelete: Restrict)
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Restrict)
  termId    String
  term      Term    @relation(fields: [termId], references: [id], onDelete: Restrict)

  // Workspace fields (teacher-defined) — replaces former Subject FK
  name        String // "คณิตศาสตร์ ม.4 ครูสมชาย"
  subjectCode String? // optional teacher-set code for transcript ("MATH-M4")
  gradeLevel  String // "ม.4" (defaults to class.gradeLevel on create)
  creditHours Float // หน่วยกิต e.g. 1.5

  classCode      String    @unique
  codeActive     Boolean   @default(true)
  codeExpiresAt  DateTime?
  gradeRulesJson Json? // override default grade thresholds
  createdAt      DateTime  @default(now())

  enrollments    Enrollment[]
  timetableSlots TimetableSlot[]
  sessions       Session[]

  @@index([classCode])
  @@index([teacherId])
  @@index([classId, termId])
}

model Enrollment {
  id               String         @id @default(cuid())
  studentId        String
  student          Student        @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  enrolledAt       DateTime       @default(now())

  // Phase 3 — soft-delete + audit trail (ADR-0013)
  removedAt     DateTime?
  removedById   String? // User.id of the teacher who removed (or admin for moderation)
  removedReason String? // Min 5 chars enforced at API boundary

  attendanceRecords AttendanceRecord[]

  @@unique([studentId, courseOfferingId])
  @@index([courseOfferingId])
  @@index([removedAt]) // fast "active members" filtering (where removedAt: null)
}

// ═══════════════════════════════════════════════════════════
// Attendance (Phase 4) — ADR-0015 (lazy materialization) · ADR-0016 (sparse records + Enrollment FK)
// ═══════════════════════════════════════════════════════════

// Template — recurring weekly schedule. Optional per CourseOffering.
// Editing/deleting a slot does NOT propagate to existing Session rows (ADR-0015 § 4).
model TimetableSlot {
  id               String         @id @default(cuid())
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  dayOfWeek        Int            // 0=Sun..6=Sat (matches JS Date.getDay())
  startTime        String         // "HH:mm" 24h, local Bangkok time
  endTime          String         // "HH:mm" 24h, local Bangkok time
  location         String?        // "อาคาร 3 ห้อง 305"
  createdAt        DateTime       @default(now())

  sessions Session[]

  // Intra-course overlap blocking: exact duplicate slot rejected at DB layer.
  // Time-range overlap (different startTime) blocked at lib layer (Q4a).
  @@unique([courseOfferingId, dayOfWeek, startTime])
  @@index([courseOfferingId])
}

// Concrete class meeting — materialized lazily on first teacher action.
// Created via findOrCreateSession({courseOfferingId, scheduledStart, ...}).
model Session {
  id               String         @id @default(cuid())
  courseOfferingId String
  course           CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)

  // Provenance — null = manually opened ad-hoc.
  // SetNull so deleting a TimetableSlot does not orphan historical Sessions.
  timetableSlotId String?
  timetableSlot   TimetableSlot? @relation(fields: [timetableSlotId], references: [id], onDelete: SetNull)

  scheduledStart DateTime // UTC instant (Postgres TIMESTAMPTZ); display layer converts to Asia/Bangkok
  scheduledEnd   DateTime
  note           String?

  // Soft-cancel — see ADR-0015 § 3, audit event SESSION_CANCELLED (Critical tier).
  cancelledAt     DateTime?
  cancelledById   String?
  cancelledReason String? // Min 5 chars enforced at action layer

  createdAt   DateTime @default(now())
  createdById String   // Teacher who opened the session (Restrict via Teacher FK enforced at lib layer)

  records AttendanceRecord[]

  // Prevents race-condition double-create from concurrent "เปิดคาบ" clicks.
  @@unique([courseOfferingId, scheduledStart])
  // Grid list query: "Sessions of this course, newest first"
  @@index([courseOfferingId, scheduledStart])
  @@index([timetableSlotId])
}

enum AttendanceStatus {
  PRESENT
  LATE
  EXCUSED
  ABSENT
}

// Sparse — no row = "ยังไม่เช็ค" (not yet marked), distinct from ABSENT (ADR-0016 § 1).
model AttendanceRecord {
  id           String           @id @default(cuid())
  sessionId    String
  session      Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollmentId String
  enrollment   Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  status       AttendanceStatus
  note         String? // "ลาป่วยมีใบรับรอง", "สาย 15 นาที"

  markedAt   DateTime @default(now()) // first mark — stable
  markedById String                    // teacher who last marked (overwritten on edit)
  updatedAt  DateTime @updatedAt
  editCount  Int      @default(0)      // increments on each edit; back-edit reason required when scheduledStart > 24h ago

  @@unique([sessionId, enrollmentId])
  @@index([enrollmentId]) // student stats query
  @@index([sessionId])
}

// ═══════════════════════════════════════════════════════════
// Rate Limit (in-DB, fallback when Redis not available)
// Phase 1 simple version — Phase 9 migrate to Upstash Redis
// ═══════════════════════════════════════════════════════════

model RateLimitBucket {
  id        String   @id // "<action>:<identifier>" e.g. "login:admin@example.com"
  count     Int      @default(0)
  resetAt   DateTime
  lockedAt  DateTime?
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}
